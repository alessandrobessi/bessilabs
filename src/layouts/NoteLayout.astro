---
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import { ROOMS } from '../lib/rooms';
import '../styles/prose.css';

interface Props {
  title: string;
  date: Date;
  updated?: Date;
  room: string;
  type: string;
  tags: string[];
  summary: string;
  status: string;
  featured?: boolean;
}

const { title, date, updated, room, type, tags, summary, status } = Astro.props;

const roomData = ROOMS.find((r) => r.slug === room);

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={summary}
  ogType="article"
  articleDate={date}
>
  <article class="container container--narrow note-article">
    <header class="note-header">
      <div class="note-header__meta">
        <time datetime={date.toISOString()} class="mono muted note-header__date">{formattedDate}</time>
        {roomData && (
          <a href={`/rooms/${room}`} class="room-pill">{roomData.name}</a>
        )}
        <span class="type-label">{type}</span>
        <span class="status-badge">{status}</span>
      </div>
      <h1 class="note-header__title">{title}</h1>
      <p class="note-header__summary">{summary}</p>
      {formattedUpdated && updated && updated.getTime() !== date.getTime() && (
        <p class="mono muted note-header__updated">Updated {formattedUpdated}</p>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="note-footer">
      {tags.length > 0 && (
        <div class="note-footer__tags">
          <TagList tags={tags} />
        </div>
      )}
      <div class="note-footer__nav">
        <a href="/notes" class="mono muted">← All notes</a>
        {roomData && (
          <a href={`/rooms/${room}`} class="mono muted">More from {roomData.name} →</a>
        )}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .note-article {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .note-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .note-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .note-header__date {
    font-size: 0.78rem;
  }

  .note-header__title {
    font-size: 2.2rem;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-sm);
    max-width: 22ch;
  }

  .note-header__summary {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: var(--measure);
    margin-bottom: 0;
    font-style: italic;
  }

  .note-header__updated {
    margin-top: var(--space-xs);
    margin-bottom: 0;
    font-size: 0.75rem;
  }

  .note-footer {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .note-footer__nav {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .note-footer__nav a {
    font-size: 0.8rem;
    text-decoration: none;
  }

  .note-footer__nav a:hover {
    color: var(--color-text);
  }
</style>
