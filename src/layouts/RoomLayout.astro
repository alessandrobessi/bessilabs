---
import BaseLayout from './BaseLayout.astro';
import type { Room } from '../lib/rooms';

interface Props {
  room: Room;
}

const { room } = Astro.props;
---

<BaseLayout
  title={room.name}
  description={room.description}
>
  <div class="container">
    <header class="room-header">
      <p class="room-header__label mono muted">Room</p>
      <h1 class="room-header__name">{room.name}</h1>
      <p class="room-header__tagline">{room.tagline}</p>
      <p class="room-header__description">{room.description}</p>
      <ul class="room-header__themes" aria-label="Themes in this room">
        {room.themes.map((theme) => (
          <li>{theme}</li>
        ))}
      </ul>
    </header>
    <slot />
  </div>
</BaseLayout>

<style>
  .room-header {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
    max-width: var(--measure-wide);
  }

  .room-header__label {
    margin-bottom: var(--space-xs);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .room-header__name {
    font-size: 3rem;
    margin-bottom: var(--space-xs);
  }

  .room-header__tagline {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .room-header__description {
    max-width: var(--measure);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .room-header__themes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .room-header__themes li {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--color-text-faint);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    padding: 0.2em 0.55em;
    border-radius: var(--radius-sm);
    margin-bottom: 0;
  }
</style>
