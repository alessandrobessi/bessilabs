---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/config';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  articleDate?: Date;
  noIndex?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  canonicalURL = new URL(Astro.url.pathname, SITE.url).toString(),
  ogType = 'website',
  ogImage = `${SITE.url}/og-image.png`,
  articleDate,
  noIndex = false,
} = Astro.props;

const pageTitle = title === SITE.title ? title : `${title} — ${SITE.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:image" content={ogImage} />
    {articleDate && <meta property="article:published_time" content={articleDate.toISOString()} />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} — RSS`} href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
