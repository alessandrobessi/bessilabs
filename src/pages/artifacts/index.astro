---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArtifacts = (await getCollection('artifacts'))
  .filter((a) => a.data.visibility === 'public')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Artifacts"
  description="Tangible outputs from the lab — code, diagrams, drawings, music recordings, and other made things."
>
  <div class="container">
    <header class="artifacts-header">
      <h1>Artifacts</h1>
      <p class="muted">
        Tangible outputs from the lab: code, diagrams, drawings, music recordings, chess studies, and other made things.
      </p>
    </header>

    {allArtifacts.length === 0 ? (
      <div class="artifacts-empty">
        <p class="mono muted">No artifacts yet. Work is being built.</p>
      </div>
    ) : (
      <div class="artifacts-list">
        {allArtifacts.map((artifact) => (
          <article class="artifact-card">
            <div class="artifact-card__meta">
              <time datetime={artifact.data.date.toISOString()} class="mono muted">
                {artifact.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span class="type-label">{artifact.data.type}</span>
            </div>
            <h2 class="artifact-card__title">
              <a href={`/artifacts/${artifact.id}`}>{artifact.data.title}</a>
            </h2>
            <p class="artifact-card__summary muted">{artifact.data.summary}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .artifacts-header {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
    max-width: var(--measure);
  }

  .artifacts-header h1 {
    margin-bottom: var(--space-sm);
  }

  .artifacts-empty {
    padding-bottom: var(--space-xl);
  }

  .artifacts-list {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-xl);
    max-width: var(--measure-wide);
  }

  .artifact-card {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .artifact-card:last-child {
    border-bottom: none;
  }

  .artifact-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: 0.4rem;
  }

  .artifact-card__meta time {
    font-size: 0.75rem;
  }

  .artifact-card__title {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
    margin-top: 0;
  }

  .artifact-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .artifact-card__title a:hover {
    color: var(--color-accent-dark);
  }

  .artifact-card__summary {
    font-size: 0.95rem;
    margin-bottom: 0;
    max-width: var(--measure);
  }
</style>
